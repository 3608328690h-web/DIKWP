{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT Submission",
  "type": "object",
  "required": [
    "submission_id",
    "agent_id",
    "system_description",
    "traces",
    "declaration"
  ],
  "properties": {
    "submission_id": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "system_description": {
      "type": "string"
    },
    "traces": {
      "type": "array",
      "items": {
        "$ref": "trace.schema.json"
      }
    },
    "declaration": {
      "type": "object",
      "required": [
        "no_hidden_manual_edits",
        "no_benchmark_leakage_claim",
        "limitations_disclosed"
      ]
    }
  }
}