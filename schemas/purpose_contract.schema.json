{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT Purpose Contract",
  "type": "object",
  "required": [
    "contract_id",
    "version",
    "purpose",
    "allowed_tools",
    "forbidden_tools",
    "human_approval_required",
    "kill_conditions"
  ],
  "properties": {
    "contract_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_approval_required": {
      "type": "boolean"
    },
    "kill_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}